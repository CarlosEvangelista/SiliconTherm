{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "rust",
      "package-name": "silicontherm_rs",
      "include-component-in-tag": false
    }
  },
  "pull-request-header": "Automated release PR generated by release-please.",
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "test",
      "section": "Tests"
    },
    {
      "type": "chore",
      "section": "Maintenance",
      "hidden": false
    },
    {
      "type": "docs",
      "section": "Documentation",
      "hidden": false
    }
  ]
}
